{
    "name": "catalyst-monorepo",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "setup": "npm install --ignore-scripts && npm --prefix docs install --ignore-scripts",
        "core:build": "npm run prepare --workspace packages/catalyst-core",
        "core:test": "sh ./scripts/test-catalyst-core.sh",
        "cca:test": "sh ./scripts/test-cca-smoke.sh",
        "cca:sync-templates": "node scripts/release/sync-cca-templates.js",
        "docs:build": "npm --prefix docs run build",
        "docs:start": "npm --prefix docs run start",
        "lint": "npm run lint --workspaces --if-present",
        "lint-staged": "lint-staged"
    },
    "devDependencies": {
        "husky": "^9.0.11",
        "lint-staged": "^15.2.2"
    }
}
